{
  "appId": "com.storemybits.peftlogbook",
  "appName": "Peft Logbook",
  "webDir": "www",
  "backgroundColor": "#0A1522",
  "android": {
    "backgroundColor": "#0A1522"
  },
  "ios": {
    "backgroundColor": "#0A1522",
    "contentInset": "always"
  },
  "plugins": {
    "CapacitorUpdater": {
      "autoUpdate": false
    },
    "SplashScreen": {
      "launchShowDuration": 400,
      "backgroundColor": "#0A1522",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
